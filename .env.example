# Railway runtime
PORT=4173
RUN_TOKEN=replace-with-long-random-token
LEAD_LIMIT=1

# Lead source: ContactOut only
CONTACTOUT_API_URL=https://api.contactout.example/leads
CONTACTOUT_API_TOKEN=replace_me

# Astra Cloud hosted production or Astra Private
ASTRA_BASE_URL=https://app.codeastra.dev
ASTRA_API_KEY=sk_replace_me
ASTRA_WORLD_ID=sales_world

# AI drafting
AI_API_KEY=replace_me
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.6-luna

# Resend email delivery and email review queue
RESEND_API_KEY=re_replace_me
EMAIL_FROM=sales@yourdomain.com
REVIEW_EMAIL=founder@yourdomain.com

# Google Calendar
GOOGLE_CALENDAR_ACCESS_TOKEN=replace_me
GOOGLE_CALENDAR_ID=primary
