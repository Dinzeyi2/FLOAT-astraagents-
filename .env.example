# Railway runtime
PORT=4173
RUN_TOKEN=replace-with-long-random-token

# X/Twitter Autonomous Growth Agent
X_API_BASE_URL=https://api.x.com
X_BEARER_TOKEN=replace_me
X_USER_ACCESS_TOKEN=replace_me
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
DATABASE_URL=postgresql://user:password@host:port/database
X_DAILY_OPPORTUNITIES_TARGET=10000
X_MAX_POSTS_PER_DAY=50
X_MAX_REPLIES_PER_DAY=200
X_SEARCH_QUERY=("AI agents" OR "workflow automation" OR "invoice approval") -is:retweet lang:en
X_MAX_CANDIDATES_PER_CYCLE=20
X_POLL_INTERVAL_MS=300000
X_HUMAN_REVIEW=true
# Keep false until you have tested drafts and review behavior with your X account.
X_LIVE_POSTING=false
